# Turso Database Configuration (Optional)
# To use Turso cloud database instead of local SQLite, set these environment variables:

# Database URL from Turso dashboard (libsql://xxx.turso.io)
TURSO_DB_URL=libsql://your-database.turso.io

# Authentication token from Turso dashboard
TURSO_AUTH_TOKEN=your-auth-token

# When these are set, the app will automatically connect to Turso
# When not set, the app will use local SQLite (data.db)
